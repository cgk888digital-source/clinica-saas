{
  "version": 2,
  "outputDirectory": "deploy_ready",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
